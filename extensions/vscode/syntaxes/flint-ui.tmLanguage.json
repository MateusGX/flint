{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Flint UI",
  "scopeName": "source.flint-ui",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#uses"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#routes"
    },
    {
      "include": "#render"
    },
    {
      "include": "source.flint"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.flint-ui",
          "match": ";.*$"
        }
      ]
    },
    "uses": {
      "patterns": [
        {
          "name": "meta.directive.use.flint-ui",
          "match": "^\\s*(@use)\\s+(\"(?:\\\\[nt\"\\\\]|[^\"])*\")\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.import.flint-ui"
            },
            "2": {
              "name": "string.quoted.double.include-path.flint-ui"
            }
          }
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "name": "meta.section.flint-ui",
          "match": "^\\s*(section)\\s+(\\.route|\\.data|\\.bss|\\.text|\\.render)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.section.flint-ui"
            },
            "2": {
              "name": "constant.language.section.flint-ui"
            }
          }
        }
      ]
    },
    "routes": {
      "patterns": [
        {
          "name": "meta.route.flint-ui",
          "match": "^\\s*(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)\\s+(\"(?:\\\\[nt\"\\\\]|[^\"])*\")\\s*$",
          "captures": {
            "1": {
              "name": "constant.language.http-method.flint-ui"
            },
            "2": {
              "name": "string.quoted.double.route-path.flint-ui"
            }
          }
        }
      ]
    },
    "render": {
      "patterns": [
        {
          "name": "meta.render.command.flint-ui",
          "match": "^\\s*(window|navbar|layout|sidebar|main|card|block|table|tfoot|menu|list|ol|row|col|toolbar|action_bar|accordion|item|breadcrumb|pagination|steps|tree|group|form|fieldset|footer|tabs|panel|select|dialog|nav\\*?|active|li|head|step|crumb|page|current|tab|tabs_body|option|field|btn|text|title|badge|divider|caption|empty|code|kbd|link|image|stat|alert|status|progress|meter|submit|input|password|number|file|textarea|checkbox|radio|hidden|dialog_trigger|dialog_alert|dialog_confirm|dialog_prompt|end)\\b",
          "captures": {
            "1": {
              "name": "support.function.render.flint-ui"
            }
          }
        }
      ]
    }
  }
}
