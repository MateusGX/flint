{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Flint UI",
  "scopeName": "text.html.flint-ui",
  "patterns": [
    {
      "include": "#page-directives"
    },
    {
      "include": "#output-expression"
    },
    {
      "include": "#code-block"
    },
    {
      "include": "text.html.basic"
    }
  ],
  "repository": {
    "page-directives": {
      "patterns": [
        {
          "name": "meta.directive.page.flint-ui",
          "match": "^\\s*(@page)(?:\\s+(?:(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)\\s+)?(\"(?:\\\\[nt\"\\\\]|[^\"])*\"))?\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.directive.page.flint-ui"
            },
            "2": {
              "name": "constant.language.http-method.flint-ui"
            },
            "3": {
              "name": "string.quoted.double.route-path.flint-ui"
            }
          }
        },
        {
          "name": "meta.directive.route.flint-ui",
          "match": "^\\s*(@route)\\s+(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)\\s+(\"(?:\\\\[nt\"\\\\]|[^\"])*\")\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.directive.route.flint-ui"
            },
            "2": {
              "name": "constant.language.http-method.flint-ui"
            },
            "3": {
              "name": "string.quoted.double.route-path.flint-ui"
            }
          }
        },
        {
          "name": "meta.directive.use.flint-ui",
          "match": "^\\s*(@use)\\s+(\"(?:\\\\[nt\"\\\\]|[^\"])*\")\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.directive.use.flint-ui"
            },
            "2": {
              "name": "string.quoted.double.include-path.flint-ui"
            }
          }
        }
      ]
    },
    "output-expression": {
      "name": "meta.embedded.output.flint-ui",
      "begin": "<%=",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.embedded.begin.flint-ui"
        }
      },
      "end": "%>",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.embedded.end.flint-ui"
        }
      },
      "contentName": "source.flint.embedded.html",
      "patterns": [
        {
          "include": "source.flint"
        }
      ]
    },
    "code-block": {
      "name": "meta.embedded.block.flint-ui",
      "begin": "<%(?![=])",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.embedded.begin.flint-ui"
        }
      },
      "end": "%>",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.embedded.end.flint-ui"
        }
      },
      "contentName": "source.flint.embedded.html",
      "patterns": [
        {
          "include": "source.flint"
        }
      ]
    }
  }
}
