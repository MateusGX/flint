{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Flint",
  "scopeName": "source.flint",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#routes"
    },
    {
      "include": "#includes"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#labels"
    },
    {
      "include": "#instructions"
    },
    {
      "include": "#native-functions"
    },
    {
      "include": "#registers"
    },
    {
      "include": "#memory"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.flint",
          "match": ";.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.flint",
      "begin": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.flint"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.flint"
        }
      },
      "patterns": [
        {
          "name": "constant.character.escape.flint",
          "match": "\\\\[nt\"\\\\]"
        },
        {
          "name": "invalid.illegal.escape.flint",
          "match": "\\\\."
        }
      ]
    },
    "routes": {
      "patterns": [
        {
          "name": "meta.route.flint",
          "match": "^\\s*(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)\\s+(\"(?:\\\\[nt\"\\\\]|[^\"])*\")\\s*(->)\\s*([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": {
              "name": "constant.language.http-method.flint"
            },
            "2": {
              "name": "string.quoted.double.route-path.flint"
            },
            "3": {
              "name": "keyword.operator.arrow.flint"
            },
            "4": {
              "name": "entity.name.function.handler.flint"
            }
          }
        }
      ]
    },
    "includes": {
      "patterns": [
        {
          "name": "meta.include.flint",
          "match": "^\\s*(use)\\s+(\"(?:\\\\[nt\"\\\\]|[^\"])*\")",
          "captures": {
            "1": {
              "name": "keyword.control.import.flint"
            },
            "2": {
              "name": "string.quoted.double.include-path.flint"
            }
          }
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "name": "meta.section.flint",
          "match": "^\\s*(section)\\s+(\\.route|\\.text|\\.data|\\.bss)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.section.flint"
            },
            "2": {
              "name": "constant.language.section.flint"
            }
          }
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "meta.label.flint",
          "match": "^\\s*(\\.?[A-Za-z_][A-Za-z0-9_.]*)(:)",
          "captures": {
            "1": {
              "name": "entity.name.label.flint"
            },
            "2": {
              "name": "punctuation.separator.colon.flint"
            }
          }
        }
      ]
    },
    "instructions": {
      "patterns": [
        {
          "name": "keyword.mnemonic.flint",
          "match": "(?i)^\\s*\\b(mov|add|sub|mul|div|mod|addf|subf|mulf|divf|and|or|xor|not|shl|shr|neg|typeof|cmp|jmp|je|jne|jl|jg|jle|jge|push|pop|call|ret|hlt|load|store|ncall|ncallr|data|res)\\b"
        }
      ]
    },
    "native-functions": {
      "patterns": [
        {
          "name": "support.function.native.flint",
          "match": "\\b(debug|string|json|math|time|env|crypto|ui|http)\\.[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "registers": {
      "patterns": [
        {
          "name": "variable.language.register.flint",
          "match": "\\br(?:1[0-5]|[0-9])\\b"
        }
      ]
    },
    "memory": {
      "patterns": [
        {
          "name": "meta.memory.flint",
          "begin": "\\[",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.memory.begin.flint"
            }
          },
          "end": "\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.memory.end.flint"
            }
          },
          "patterns": [
            {
              "include": "#registers"
            },
            {
              "include": "#numbers"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.flint",
          "match": "(?<![A-Za-z0-9_.])-?[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.flint",
          "match": "(?<![A-Za-z0-9_.])-?[0-9]+\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.flint",
          "match": ","
        },
        {
          "name": "keyword.operator.arrow.flint",
          "match": "->"
        }
      ]
    }
  }
}
