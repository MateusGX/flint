{
  "name": "flint-vscode",
  "displayName": "Flint Language",
  "description": "Language support for Flint route modules, HTML pages, and UI pages.",
  "version": "0.1.0",
  "icon": "images/icon.png",
  "publisher": "mateusam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MateusGX/flint",
    "directory": "extensions/vscode"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "vscode:prepublish": "pnpm run compile",
    "package": "pnpm run compile && pnpm dlx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "flint",
    "assembly",
    "bytecode",
    "http",
    "templates"
  ],
  "contributes": {
    "languages": [
      {
        "id": "flint",
        "aliases": [
          "Flint",
          "flint"
        ],
        "extensions": [
          ".fl"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "flint-html",
        "aliases": [
          "Flint HTML",
          "flint-html"
        ],
        "extensions": [
          ".flint.html"
        ],
        "configuration": "./page-language-configuration.json"
      },
      {
        "id": "flint-ui",
        "aliases": [
          "Flint UI",
          "flint-ui"
        ],
        "extensions": [
          ".flint.ui"
        ],
        "configuration": "./page-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "flint",
        "scopeName": "source.flint",
        "path": "./syntaxes/flint.tmLanguage.json"
      },
      {
        "language": "flint-html",
        "scopeName": "text.html.flint",
        "path": "./syntaxes/flint-html.tmLanguage.json",
        "embeddedLanguages": {
          "source.flint.embedded.html": "flint",
          "text.html.basic": "html"
        }
      },
      {
        "language": "flint-ui",
        "scopeName": "text.html.flint-ui",
        "path": "./syntaxes/flint-ui.tmLanguage.json",
        "embeddedLanguages": {
          "source.flint.embedded.html": "flint",
          "text.html.basic": "html"
        }
      }
    ],
    "snippets": [
      {
        "language": "flint",
        "path": "./snippets/flint.code-snippets"
      },
      {
        "language": "flint-html",
        "path": "./snippets/flint-html.code-snippets"
      },
      {
        "language": "flint-ui",
        "path": "./snippets/flint-ui.code-snippets"
      }
    ],
    "configurationDefaults": {
      "[flint]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
      },
      "[flint-html]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
      },
      "[flint-ui]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
      }
    }
  }
}
