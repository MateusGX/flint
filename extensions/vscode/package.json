{
  "name": "flint-vscode",
  "displayName": "Flint Language",
  "description": "Language support for Flint route modules and UI pages.",
  "version": "0.2.2",
  "icon": "images/icon.png",
  "publisher": "mateusam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MateusGX/flint",
    "directory": "extensions/vscode"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:flint",
    "onLanguage:flint-ui"
  ],
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "vscode:prepublish": "pnpm run compile",
    "package": "pnpm run compile && pnpm dlx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "flint",
    "assembly",
    "bytecode",
    "http",
    "ui"
  ],
  "contributes": {
    "languages": [
      {
        "id": "flint",
        "aliases": [
          "Flint",
          "flint"
        ],
        "extensions": [
          ".fl"
        ],
        "icon": {
          "light": "./icons/flint.svg",
          "dark": "./icons/flint.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "flint-ui",
        "aliases": [
          "Flint UI",
          "flint-ui"
        ],
        "extensions": [
          ".flint.ui"
        ],
        "icon": {
          "light": "./icons/flint-ui.svg",
          "dark": "./icons/flint-ui.svg"
        },
        "configuration": "./ui-language-configuration.json"
      },
      {
        "id": "flint-bytecode",
        "aliases": [
          "Flint Bytecode",
          "flint-bytecode"
        ],
        "extensions": [
          ".flintbc"
        ],
        "icon": {
          "light": "./icons/flint-bytecode.svg",
          "dark": "./icons/flint-bytecode.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "flint",
        "scopeName": "source.flint",
        "path": "./syntaxes/flint.tmLanguage.json"
      },
      {
        "language": "flint-ui",
        "scopeName": "source.flint-ui",
        "path": "./syntaxes/flint-ui.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "flint",
        "path": "./snippets/flint.code-snippets"
      },
      {
        "language": "flint-ui",
        "path": "./snippets/flint-ui.code-snippets"
      }
    ],
    "configurationDefaults": {
      "[flint]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
      },
      "[flint-ui]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
      }
    }
  }
}
